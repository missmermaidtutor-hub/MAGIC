rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===== USERS COLLECTION =====
    match /users/{userId} {
      // Users can read their own profile
      allow read: if request.auth != null && request.auth.uid == userId;

      // Users can create their own profile (on signup)
      allow create: if request.auth != null
                    && request.auth.uid == userId
                    && request.resource.data.uid == userId;

      // Users can update their own profile
      // Cannot change uid, email, or accountMethod after creation
      allow update: if request.auth != null
                    && request.auth.uid == userId
                    && request.resource.data.uid == resource.data.uid
                    && request.resource.data.email == resource.data.email
                    && request.resource.data.accountMethod == resource.data.accountMethod;

      // No deletes allowed
      allow delete: if false;

      // ----- User Subcollections -----

      // Artworks — owner read/write only
      match /artworks/{artworkId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
        allow delete: if request.auth != null && request.auth.uid == userId;
      }

      // Inspirations — owner read/write only
      match /inspirations/{inspirationId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
        allow delete: if request.auth != null && request.auth.uid == userId;
      }

      // Curated — owner write, all authenticated users read
      match /curated/{curatedId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && request.auth.uid == userId;
        allow delete: if request.auth != null && request.auth.uid == userId;
      }

      // Manifests — owner read/write only
      match /manifests/{date} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Progress — owner read/write only
      match /progress/{date} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Art Time — owner read/write only
      match /artTime/{date} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Goals — owner read/write only
      match /goals/{date} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // ===== PSEUDONYMS COLLECTION =====
    match /pseudonyms/{pseudonymId} {
      // Anyone authenticated can check if a pseudonym is available
      allow read: if request.auth != null;

      // Authenticated users can claim an unclaimed pseudonym
      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.released == false;

      // Only the owner can update (release) their pseudonym
      // Or reclaim a released pseudonym
      allow update: if request.auth != null
                    && (
                      // Owner releasing their pseudonym
                      (resource.data.uid == request.auth.uid)
                      ||
                      // Someone claiming a released pseudonym
                      (resource.data.released == true
                       && request.resource.data.uid == request.auth.uid
                       && request.resource.data.released == false)
                    );

      // Pseudonyms are never deleted
      allow delete: if false;
    }

    // ===== USERNAMES COLLECTION =====
    match /usernames/{usernameId} {
      // Anyone authenticated can check if a username is available
      allow read: if request.auth != null;

      // Authenticated users can claim an unclaimed username
      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.released == false;

      // Only the owner can update (release) their username
      // Or reclaim a released username
      allow update: if request.auth != null
                    && (
                      (resource.data.uid == request.auth.uid)
                      ||
                      (resource.data.released == true
                       && request.resource.data.uid == request.auth.uid
                       && request.resource.data.released == false)
                    );

      // Usernames are never deleted
      allow delete: if false;
    }

    // ===== DAILY COURAGES COLLECTION =====
    match /dailyCourages/{courageId} {
      // All authenticated users can read courages (for voting)
      allow read: if request.auth != null;

      // Authenticated users can create their own courage
      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid;

      // No updates or deletes
      allow update, delete: if false;
    }

    // ===== VOTING GALLERY COLLECTION =====
    match /votingGallery/{dateId} {
      allow read: if request.auth != null;

      match /entries/{entryId} {
        // All authenticated users can read voting entries
        allow read: if request.auth != null;

        // Only authenticated users can create (transfer function)
        allow create: if request.auth != null;

        // No updates or deletes
        allow update, delete: if false;
      }
    }

    // ===== VOTES COLLECTION =====
    match /votes/{voteId} {
      // Users can read their own votes
      allow read: if request.auth != null;

      // Authenticated users can create votes (not for their own courage)
      allow create: if request.auth != null
                    && request.resource.data.voterUid == request.auth.uid;

      // No updates or deletes
      allow update, delete: if false;
    }

    // ===== DAILY WINNERS COLLECTION =====
    match /dailyWinners/{dateId} {
      // All authenticated users can read winners
      allow read: if request.auth != null;

      // Any authenticated user can create a winner (first-writer wins via transaction)
      allow create: if request.auth != null;

      // No updates or deletes
      allow update, delete: if false;
    }

    // ===== DAILY PROMPTS COLLECTION =====
    match /dailyPrompts/{dateId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
